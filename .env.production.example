# ════════════════════════════════════════════════════════════════════════════
# RAILWAY ENVIRONMENT VARIABLES
# Copy these to Railway Dashboard → Your Project → Variables tab
# DO NOT commit actual values to git
# ════════════════════════════════════════════════════════════════════════════

APP_NAME="Kaon Time POS"
APP_ENV=production
APP_KEY=base64:Ze1slGoQ3nxnfbGBS7SBf/s0luxI1O45AVX1y4L/xIM=
APP_DEBUG=false
APP_URL=https://YOUR-BACKEND.up.railway.app

# ─── Database (Railway will auto-inject these if you add a PostgreSQL service) ───
DB_CONNECTION=pgsql
DB_HOST=${{Postgres.PGHOST}}
DB_PORT=${{Postgres.PGPORT}}
DB_DATABASE=${{Postgres.PGDATABASE}}
DB_USERNAME=${{Postgres.PGUSER}}
DB_PASSWORD=${{Postgres.PGPASSWORD}}

# ─── Store Info ───
STORE_NAME="Kaon Time"
STORE_ADDRESS="Ampayon, Butuan City"
STORE_PHONE="09458572362"

# ─── Laravel Config ───
LOG_CHANNEL=stack
LOG_LEVEL=error
BCRYPT_ROUNDS=12

SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# ─── CORS (allow your frontend) ───
FRONTEND_URL=https://YOUR-FRONTEND.vercel.app
SANCTUM_STATEFUL_DOMAINS=YOUR-FRONTEND.vercel.app,localhost:5173
